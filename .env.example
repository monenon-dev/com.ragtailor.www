# 로컬 개발 예시
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Google 로그인 — backend/.env의 GOOGLE_CLIENT_ID와 동일 값
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Vercel 배포 시 백엔드 공개 URL (끝에 / 없이)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Vercel Blob (로컬·Docker — Read-Write Token, Vercel 대시보드 Blob 스토어에서 발급)
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=
# BLOB_WEBHOOK_PUBLIC_KEY=
# vercel env pull 은 .env.local 대신 .env.vercel 사용 권장
